{
  "defaultProvider": "anthropic",
  "providers": {
    "anthropic": {
      "model": "claude-sonnet-4-6",
      "apiKeyEnv": "ANTHROPIC_API_KEY"
    },
    "openai": {
      "model": "gpt-4o",
      "apiKeyEnv": "OPENAI_API_KEY"
    },
    "ollama": {
      "model": "llama3",
      "baseUrl": "http://localhost:11434"
    }
  },
  "roles": {
    "compile": "anthropic",
    "query": "anthropic",
    "summarize": "anthropic",
    "lint": "anthropic"
  }
}
